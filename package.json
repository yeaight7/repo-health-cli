{
  "name": "repo-health-audit",
  "version": "0.1.2",
  "description": "Audit local repositories for open-source readiness and actionable health recommendations.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yeaight7/repo-health-cli.git"
  },
  "keywords": [
    "cli",
    "repository",
    "audit",
    "open-source",
    "health"
  ],
  "bin": {
    "repo-health": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test:pack": "node test/package-smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=20"
  }
}
